	(text "Break-Off Program/Test Header Section"
		(exclude_from_sim no)
		(at 64.262 117.856 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "0568c203-fcd5-45dd-bd76-efd6ac93ebb6")
	)
	(text "CSPI = Configuration SPI (FPGA to its own config flash)\nHSPI = Host SPI (FPGA to host BIOS flash/PCH SPI bus)"
		(exclude_from_sim no)
		(at 161.036 124.714 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "1aede691-b15b-4442-8ee5-b3a701fcec83")
	)
	(text "VBUS is the voltage of the host flash chip (1.8V or 3.3V)\nIt powers most voltage rails of the iCE40 directly.\nHowever, VPP_2V5 must not be below 2.5V even on 1.8V hosts.\n\nOn 3.3V boards, populate this resistor to power VPP_2V5 with 3.3V\n(3.3 instead of 2.5 is okay except for NVCM programming)\n\nOn 1.8V boards, an external 3.3V supply is required. Remove this\nresistor and solder a wire from 3.3V somewhere on the host board\nto the 3V3 pad."
		(exclude_from_sim no)
		(at 138.176 185.928 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "4f38d1a7-b3bd-4a78-8fc8-4670235bffdd")
	)
	(text "4 Mbit. Configuration for iCE40UP5K is 833288 bits (fits in 1 Mbit)\nIf 16 Mbit is needed, research AT25FF161A (16 Mbit, same pinout),\nbut beware different recommended BGA pad diameter."
		(exclude_from_sim no)
		(at 249.682 160.528 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "c6554a22-e8d9-48b8-924e-ff5d4755f028")
	)
	(text "reorder if needed"
		(exclude_from_sim no)
		(at 108.204 103.124 90)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "d1ce593e-9298-4424-a8e5-dd8a48c5155d")
	)
